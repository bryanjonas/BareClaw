# Secrets file — KEY=VALUE format, never committed (except this example).
# Consider: chmod 600 secrets/<id>.env
#
# 1. Provider API keys: filename must match a provider id in config.yaml providers:
#
#    File: secrets/openai.env
#      api_key=sk-proj-...
#
#    File: secrets/openrouter.env
#      api_key=sk-or-v1-...
#      # Get your key at: https://openrouter.ai/keys
#
#    File: secrets/anthropic.env
#      api_key=sk-ant-...
#
# 2. Superpower secrets: filename must match the id in superpowers/<id>.yaml
#
#    File: secrets/homeassistant.env
#      token=your-long-lived-token
#
# The LLM sees the file path and variable names — not the values.
# Use in run_command:
#   source /abs/path/to/secrets/homeassistant.env && curl -H "Authorization: Bearer $token" ...

token=your-api-token-here
